library(httr)
library(sf)
url <- parse_url("https://data-gis.unep-wcmc.org/server/rest/services")
url$path <- paste(url$path, "GADM_EEZ_Layer/FeatureServer/0/query", sep = "/")
# Define the conditions for the "where" parameter
