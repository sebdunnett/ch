tiles
unique_combos = data.frame(matrix(ncol=52, nrow=0))
colnames(unique_combos) <- names(feature_stack)
counter = 0
for(tile_path in tiles){
tile = rast(tile_path)
tile_vals = as.data.frame(tile, xy=TRUE)
# find new combos not yet seen
new_combos = unique(select(tile_vals,-c(x,y)))
new_combos = anti_join(new_combos, unique_combos)
if(nrow(new_combos) > 0){
new_combos$VALUE = (counter+1):(counter+nrow(new_combos))
counter = counter + nrow(new_combos)
unique_combos = rbind(unique_combos, new_combos)
}
# reclassify tile by joining to combo table
tile_vals = left_join(tile_vals, unique_combos)
# write reclassified tile to disk
out = rast(tile_vals[,c("x","y","VALUE")], type="xyz", crs=crs(tile))
writeRaster(out, gsub("raw","reclassified/", tile_path), datatype="INT4U")
cat(paste0(nrow(new_combos)," found in ",tile))
}
