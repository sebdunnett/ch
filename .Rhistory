cat("read in KBAs...")
kba_aze_iba_polys = st_read(dsn = "O:/f00_data/Birdlife-001-KBA-IBA-AZE/KBAsGlobal_2024_Aug_02_POL/KBAsGlobal_2024_Aug_02_POL/KBAsGlobal_2024_Aug_02_POL.shp", quiet=TRUE)
kba_aze_iba_pts = st_read(dsn = "O:/f00_data/Birdlife-001-KBA-IBA-AZE/KBAsGlobal_2024_Aug_02_POL/KBAsGlobal_2024_Aug_02_POL/KBAsGlobal_2024_Aug_02_PNT.shp", quiet=TRUE)
cat("done\n")
`%ni%` = Negate(`%in%`)
cat("kbas...")
tic("kbas fix and union")
kba_polys = filter(kba_aze_iba_polys, KbaStatus == "confirmed") %>%
dplyr::select(Criteria) %>%
fix_sf()
kba_pts = filter(kba_aze_iba_pts, KbaStatus == "confirmed") %>%
mutate(SitArea = as.numeric(SitArea)) %>%
drop_na(SitArea)
kba_pts_buff = st_buffer_antimeridian(kba_pts, dist = sqrt((kba_pts$SitArea*10000)/pi), max_cells=5000) %>%
fix_sf() %>%
select(Criteria)
kba = bind_rows(kba_polys,kba_pts_buff)
L_C2_KBAs_B1 = filter(kba, str_detect(Criteria,"B1")) %>%
st_faster_union() %>%
mutate(Type = "Likely", Feature = "KBAs under criterion B1")
L_C2_KBAs_B2 = filter(kba, str_detect(Criteria,"B2")) %>%
st_faster_union() %>%
mutate(Type = "Likely", Feature = "KBAs under criterion B2")
