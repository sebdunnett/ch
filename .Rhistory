ch2018 = rast("O:/f01_projects_active/Global/p08868_CriticalHabitatUpdate/crhab_lpu")
terra::compareGeom(ch,ch2018)
ch2018 = rast("O:/f01_projects_active/Global/p08868_CriticalHabitatUpdate/crhab_lpu") |>
classify(rbind(c(1,0),c(2,10),c(3,1)))
crs(ch2018) = "ESRI:102100"
ch2018 = project(ch2018, ch, method="near")
terra::compareGeom(ch,ch2018)
plot(c(ch,ch2018))
ch_10km = aggregate(ch,fact=10,method="near")
ch2018_10km = aggregate(ch2018,fact=10,method="near")
plot(ch_10km)
plot(ch2018_10km)
ch_10km
writeRaster(ch_10km,"O:/f01_projects_active/Global/p08868_CriticalHabitatUpdate/paper/ch2023_10km.tif")
writeRaster(ch_10km,"O:/f01_projects_active/Global/p08868_CriticalHabitatUpdate/outputs/paper/ch2023_10km.tif")
writeRaster(ch2018_10km,"O:/f01_projects_active/Global/p08868_CriticalHabitatUpdate/outputs/paper/ch2018_10km.tif")
plot(ch2018)
