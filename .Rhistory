test_buffs2 = st_transform(test,"ESRI:54032") |>
st_buffer(50000) |>
st_transform(4326)
p_load(tmap)
tm_shape(test) +
tm_fill() +
tm_shape(test_buffs) +
tm_borders(col="red") +
tm_shape(test_buffs2) +
tm_borders(col="blue") +
tm_facets('fct') +
tm_grid()
