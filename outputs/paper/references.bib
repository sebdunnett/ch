@article{latrubesseDammingRiversAmazon2017a,
  title = {Damming the Rivers of the {{Amazon}} Basin},
  author = {Latrubesse, Edgardo M. and Arima, Eugenio Y. and Dunne, Thomas and Park, Edward and Baker, Victor R. and {d'Horta}, Fernando M. and Wight, Charles and Wittmann, Florian and Zuanon, Jansen and Baker, Paul A. and Ribas, Camila C. and Norgaard, Richard B. and Filizola, Naziano and Ansar, Atif and Flyvbjerg, Bent and Stevaux, Jose C.},
