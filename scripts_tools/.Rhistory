theme_unep_wcmc <- function() {
theme_minimal(base_family = "roboto") %+replace%
theme(
# Plot and panel background with #4D6B89 at 20% opacity
plot.background = element_rect(fill = "#d9e1ea", color = NA),
#panel.background = element_rect(fill = "#d9e1ea", color = NA),
# Legend titles in bold and uppercase
legend.title = element_text(face = "bold",
hjust = 0.5),
# Major grid lines only, white color
panel.grid.major.y = element_line(color = "white", size = 0.5),
panel.grid.minor.y = element_blank(),
panel.grid.major.x = element_blank(),
