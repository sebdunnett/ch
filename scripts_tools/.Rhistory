plot.background = element_rect(fill = "#d9e1ea", color = NA),
#panel.background = element_rect(fill = "#d9e1ea", color = NA),
# Legend titles in bold and uppercase
legend.title = element_text(face = "bold",
hjust = 0.5),
# Major grid lines only, white color
panel.grid.major.y = element_line(color = "white", size = 0.5),
panel.grid.minor.y = element_blank(),
panel.grid.major.x = element_blank(),
panel.grid.minor.x = element_blank()
)
}
data <- read_csv("C:/Users/sebastiandu/Downloads/OneDrive_2025-12-01/input data/Scatter_plots_for_R_fixed_PAcover.csv")
data <- data %>%
mutate(
`Fixed tech_potential` = as.numeric(`Fixed tech_potential`),
`% PA marine cover` = as.numeric(`% PA marine cover`)
)
str(data)
x_mid <- (max(data$`Fixed tech_potential`, na.rm = TRUE) + min(data$`Fixed tech_potential`, na.rm = TRUE)) / 2
y_mid <- (max(data$`% PA marine cover`, na.rm = TRUE) + min(data$`% PA marine cover`, na.rm = TRUE)) / 2
top_countries <- data %>%
arrange(desc(`% PA marine cover`)) %>%
slice_head(n = 3)
subregion_colors <- c(
"Eastern Africa" = "#00aeef",
"Middle Africa" = "#42b072",
"Northern Africa" = "#8b6faf",
"Southern Africa" = "#ec6751",
"Western Africa" = "#fdc742"
)
quadrant_labels <- data.frame(
x = c(x_mid - 0.25 * (max(data$`Fixed tech_potential`, na.rm = TRUE) - min(data$`Fixed tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`Fixed tech_potential`, na.rm = TRUE) - min(data$`Fixed tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`Fixed tech_potential`, na.rm = TRUE) - min(data$`Fixed tech_potential`, na.rm = TRUE)),
x_mid - 0.25 * (max(data$`Fixed tech_potential`, na.rm = TRUE) - min(data$`Fixed tech_potential`, na.rm = TRUE))),
y = c(y_mid + 0.25 * (max(data$`% PA marine cover`, na.rm = TRUE) - min(data$`% PA marine cover`, na.rm = TRUE)),
y_mid + 0.25 * (max(data$`% PA marine cover`, na.rm = TRUE) - min(data$`% PA marine cover`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`% PA marine cover`, na.rm = TRUE) - min(data$`% PA marine cover`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`% PA marine cover`, na.rm = TRUE) - min(data$`% PA marine cover`, na.rm = TRUE))),
label = c("Higher Protection,\nLower Tech Potential",
"Higher Protection,\nHigher Tech Potential",
"Lower Protection,\nHigher Tech Potential",
"Lower Protection,\nLower Tech Potential")
)
a = ggplot(data, aes(x = `Fixed tech_potential`, y = `% PA marine cover`, color = Subregion)) +
geom_vline(xintercept = x_mid, color = "white", linewidth = 1) +  # Vertical line at midpoint
geom_hline(yintercept = y_mid, color = "white", linewidth = 1) +  # Horizontal line at midpoint
geom_point(size = 3) +
theme_minimal() +
geom_text_repel(data = top_countries, aes(label = Country), size = 3, nudge_y = ifelse(top_countries$Country == "South Africa", -0.5, 0.5)) +
geom_text(data = quadrant_labels, aes(x = x, y = y, label = label), size = 3, hjust = 0.5, vjust = 0.5, color = "black") +
theme_unep_wcmc() +
theme(
panel.grid.major = element_blank(),  # Remove all major gridlines
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),   # Remove minor gridlines
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
legend.text = element_text(size = 10),  # Ensure clean legend text
legend.key = element_blank()  # Remove any unnecessary legend background or markers
) +
labs(
x = "\nFixed tech potential (sqkm)",
y = "Percentage\n",
color = "SUBREGION"
) +
theme(legend.position = "none") +
scale_color_manual(values = subregion_colors) +
ggtitle("Marine PA cover")
