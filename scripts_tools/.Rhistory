library(httr)
library(sf)
url <- parse_url("https://geonode.goosocean.org/layers/geonode_data:geonode:Important_Marine_Mammal_Areas_IMMA")
url$path <- paste(url$path, "query", sep = "/")
url$query <- list(
where = "1=1",
outFields = "*",
f = "geojson"
)
# Build the URL and make the request
request <- build_url(url)
# Read the spatial data
sf <- st_read(request)
