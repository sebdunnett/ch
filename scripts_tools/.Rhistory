data <- data %>%
mutate(
`tech_potential` = as.numeric(`tech_potential`),
`No overlap (%)` = as.numeric(`No overlap (%)`)
)
str(data)
x_mid <- (max(data$`tech_potential`, na.rm = TRUE) + min(data$`tech_potential`, na.rm = TRUE)) / 2
y_mid <- (max(data$`No overlap (%)`, na.rm = TRUE) + min(data$`No overlap (%)`, na.rm = TRUE)) / 2
top_countries <- data %>%
filter(Country %in% c("Seychelles", "South Africa", "Sudan"))
subregion_colors <- c(
"Eastern Africa" = "#00aeef",
"Middle Africa" = "#42b072",
"Northern Africa" = "#8b6faf",
"Southern Africa" = "#ec6751",
"Western Africa" = "#fdc742"
)
quadrant_labels <- data.frame(
x = c(x_mid - 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid - 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE))),
y = c(y_mid + 0.25 * (max(data$`No overlap (%)`, na.rm = TRUE) - min(data$`No overlap (%)`, na.rm = TRUE)),
y_mid + 0.25 * (max(data$`No overlap (%)`, na.rm = TRUE) - min(data$`No overlap (%)`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`No overlap (%)`, na.rm = TRUE) - min(data$`No overlap (%)`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`No overlap (%)`, na.rm = TRUE) - min(data$`No overlap (%)`, na.rm = TRUE))),
label = c("Lower Overlap,\nLower Tech Potential",
"Lower Overlap,\nHigher Tech Potential",
"Higher Overlap,\nHigher Tech Potential",
"Higher Overlap,\nLower Tech Potential")
)
b = ggplot(data, aes(x = `tech_potential`, y = `No overlap (%)`, color = Subregion)) +
geom_vline(xintercept = x_mid, color = "white", linewidth = 1) +  # Vertical line at midpoint
geom_hline(yintercept = y_mid, color = "white", linewidth = 1) +  # Horizontal line at midpoint
geom_point(size = 3) +
theme_minimal() +
geom_text_repel(data = top_countries, aes(label = Country), size = 3, nudge_y = ifelse(top_countries$Country == "Seychelles", -0.5, -5)) +
geom_text(data = quadrant_labels, aes(x = x, y = y, label = label), size = 3, hjust = 0.5, vjust = 0.5, color = "black") +
theme_unep_wcmc() +
theme(
panel.grid.major = element_blank(),  # Remove all major gridlines
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),   # Remove minor gridlines
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
legend.text = element_text(size = 10),  # Ensure clean legend text
legend.key = element_blank()  # Remove any unnecessary legend background or markers
) +
labs(
x = "\nFloating tech potential (sqkm)",
y = "Percentage\n",
color = "SUBREGION"
) +
theme(legend.position = "bottom",
legend.background = element_rect(fill = "#d9e1ea", color = NA)) +
scale_color_manual(values = subregion_colors)
c = get_legend(b)
bb = ggplot(data, aes(x = `tech_potential`, y = `No overlap (%)`, color = Subregion)) +
geom_vline(xintercept = x_mid, color = "white", linewidth = 1) +  # Vertical line at midpoint
geom_hline(yintercept = y_mid, color = "white", linewidth = 1) +  # Horizontal line at midpoint
geom_point(size = 3) +
theme_minimal() +
theme_unep_wcmc() +
geom_text_repel(data = top_countries, aes(label = Country), size = 3, nudge_y = ifelse(top_countries$Country == "Seychelles", -0.5, -5)) +
geom_text(data = quadrant_labels, aes(x = x, y = y, label = label), size = 3, hjust = 0.5, vjust = 0.5, color = "black") +
theme(
panel.grid.major = element_blank(),  # Remove all major gridlines
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),   # Remove minor gridlines
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
legend.text = element_text(size = 10),  # Ensure clean legend text
legend.key = element_blank()  # Remove any unnecessary legend background or markers
) +
labs(
x = "\nFloating tech potential (sqkm)",
y = "Percentage\n",
color = "SUBREGION"
) +
theme(legend.position = "none") +
scale_color_manual(values = subregion_colors) +
ggtitle("No overlap with areas of marine conservation")
p_load(cowplot)
d = plot_grid(plot_grid(a,bb, nrow=1, labels=LETTERS[1:2], scale=0.98),c, nrow=2, rel_heights = c(0.9,0.1))
d
