)
}
# Import data
data <- read_csv("C:/Users/sebastiandu/Downloads/OneDrive_2025-12-01/input data/Scatter_plots_for_R_floating_PAcover.csv")
# Convert columns to numeric
data <- data %>%
mutate(
`tech_potential` = as.numeric(`tech_potential`),
`Marine PA (%)` = as.numeric(`Marine PA (%)`)
)
# Calculate midpoints of x and y ranges
x_mid <- (max(data$`tech_potential`, na.rm = TRUE) + min(data$`tech_potential`, na.rm = TRUE)) / 2
y_mid <- (max(data$`Marine PA (%)`, na.rm = TRUE) + min(data$`Marine PA (%)`, na.rm = TRUE)) / 2
# Find top 3 countries with highest 'Marine PA (%)'
top_countries <- data %>%
arrange(desc(`Marine PA (%)`)) %>%
slice_head(n = 3)
# Adjust label position for South Africa
top_countries <- top_countries %>%
mutate(nudge_y = ifelse(Country == "South Africa", -5, 0.5))
# Manually specify colors for subregions
subregion_colors <- c(
"Eastern Africa" = "#00aeef",
"Middle Africa" = "#42b072",
"Northern Africa" = "#8b6faf",
"Southern Africa" = "#ec6751",
"Western Africa" = "#fdc742"
)
# Create quadrant labels at the center of each quadrant
quadrant_labels <- data.frame(
x = c(x_mid - 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid + 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE)),
x_mid - 0.25 * (max(data$`tech_potential`, na.rm = TRUE) - min(data$`tech_potential`, na.rm = TRUE))),
y = c(y_mid + 0.25 * (max(data$`Marine PA (%)`, na.rm = TRUE) - min(data$`Marine PA (%)`, na.rm = TRUE)),
y_mid + 0.25 * (max(data$`Marine PA (%)`, na.rm = TRUE) - min(data$`Marine PA (%)`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`Marine PA (%)`, na.rm = TRUE) - min(data$`Marine PA (%)`, na.rm = TRUE)),
y_mid - 0.25 * (max(data$`Marine PA (%)`, na.rm = TRUE) - min(data$`Marine PA (%)`, na.rm = TRUE))),
label = c("Higher Protection,\nLower Tech Potential",
"Higher Protection,\nHigher Tech Potential",
"Lower Protection,\nHigher Tech Potential",
"Lower Protection,\nLower Tech Potential")
)
# Plot the data
a = ggplot(data, aes(x = `tech_potential`, y = `Marine PA (%)`, color = Subregion)) +
geom_vline(xintercept = x_mid, color = "white", linewidth = 1) +  # Vertical line at midpoint
geom_hline(yintercept = y_mid, color = "white", linewidth = 1) +  # Horizontal line at midpoint
geom_point(size = 3) +
theme_minimal() +
geom_text_repel(data = top_countries, aes(label = Country), size = 3, nudge_y = ifelse(top_countries$Country == "South Africa", -2, 0.5)) +
geom_text(data = quadrant_labels, aes(x = x, y = y, label = label), size = 3, hjust = 0.5, vjust = 0.5, color = "black") +
theme_unep_wcmc() +
theme(
panel.grid.major = element_blank(),  # Remove all major gridlines
panel.grid.major.x = element_blank(),
panel.grid.major.y = element_blank(),
panel.grid.minor = element_blank(),   # Remove minor gridlines
panel.grid.minor.x = element_blank(),
panel.grid.minor.y = element_blank(),
legend.text = element_text(size = 10),  # Ensure clean legend text
legend.key = element_blank()  # Remove any unnecessary legend background or markers
) +
labs(
x = "\nFloating tech potential (sqkm)",
y = "Percentage\n",
color = "SUBREGION"
) +
theme(legend.position = "none") +
scale_color_manual(values = subregion_colors) +
ggtitle("Marine protected areas cover")
